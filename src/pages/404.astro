---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';

const base = import.meta.env.BASE_URL;
---

<Base
  title="Not found — Dhruva AI"
  description="This page couldn't be found. Head back to Dhruva AI — the open-source app that runs AI models 100% on your device."
>
  <section class="notfound">
    <div class="sky" aria-hidden="true"><div class="stars"></div></div>
    <div class="wrap nf-inner">
      <div class="nf-mark">
        <div class="mark-glow" aria-hidden="true"></div>
        <Logo size={72} />
      </div>
      <p class="nf-code">404</p>
      <h1>Even the pole star can't find this one.</h1>
      <p class="nf-lede">The page you're after has drifted off the map. Everything else is still exactly where it should be.</p>
      <div class="nf-actions">
        <a class="btn btn-primary" href={base}>
          Back to home
          <span class="btn-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
        <a class="btn btn-ghost" href={`${base}build/`}>See the build</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .notfound {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: 68vh;
    display: grid;
    place-items: center;
    padding-block: var(--space-6xl);
    background: radial-gradient(110% 90% at 50% -10%, var(--color-surface), var(--color-background) 60%);
  }

  .sky {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .stars {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background-image:
      radial-gradient(1.5px 1.5px at 24% 30%, var(--color-midnight-200) 99%, transparent),
      radial-gradient(1px 1px at 52% 18%, var(--color-star-gold-200) 99%, transparent),
      radial-gradient(1.5px 1.5px at 74% 44%, var(--color-midnight-200) 99%, transparent),
      radial-gradient(1px 1px at 90% 26%, var(--color-midnight-300) 99%, transparent);
  }

  @media (prefers-color-scheme: light) {
    .stars {
      opacity: 0.2;
    }
  }

  .nf-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-base);
  }

  .nf-mark {
    position: relative;
    display: grid;
    place-items: center;
  }

  .mark-glow {
    position: absolute;
    width: 170px;
    height: 170px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 30%, transparent), transparent 62%);
    filter: blur(14px);
    z-index: -1;
  }

  .nf-code {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-headline-medium-size);
    color: var(--color-primary);
    letter-spacing: 0.1em;
  }

  .notfound h1 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-small-weight);
    font-size: clamp(var(--text-headline-medium-size), 4vw + 1rem, var(--text-display-medium-size));
    line-height: var(--text-headline-large-line-height);
    letter-spacing: var(--text-display-large-tracking);
    color: var(--color-on-background);
    max-width: 20ch;
    text-wrap: balance;
  }

  .nf-lede {
    color: var(--color-on-surface-variant);
    max-width: 46ch;
    font-size: var(--text-body-large-size);
  }

  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-base);
    margin-top: var(--space-base);
  }
</style>
