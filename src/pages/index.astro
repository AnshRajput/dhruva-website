---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import StarGlyph from '../components/StarGlyph.astro';
import Pillar from '../components/Pillar.astro';
import PhoneFrame from '../components/mockups/PhoneFrame.astro';
import ChatMock from '../components/mockups/ChatMock.astro';
import ModelsHubMock from '../components/mockups/ModelsHubMock.astro';
import CharactersMock from '../components/mockups/CharactersMock.astro';
import VisionMock from '../components/mockups/VisionMock.astro';
import ImagineMock from '../components/mockups/ImagineMock.astro';
import VoiceMock from '../components/mockups/VoiceMock.astro';
import DocsMock from '../components/mockups/DocsMock.astro';
import ToolboxMock from '../components/mockups/ToolboxMock.astro';
import PlaygroundMock from '../components/mockups/PlaygroundMock.astro';

const repo = 'https://github.com/AnshRajput/dhruva-app';
const base = import.meta.env.BASE_URL;

const proof = ['Zero telemetry', 'Apache-2.0', 'Runs offline', 'Any GGUF'];
---

<Base
  title="Dhruva AI — Your AI. Your phone. Nobody else's business."
  description="Dhruva AI is an open-source app that runs AI models 100% on your device — offline chat, characters, vision, image generation, voice, and document chat. Zero telemetry, Apache-2.0."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="sky" aria-hidden="true">
      <div class="aurora"></div>
      <div class="stars stars-far" data-parallax="0.05"></div>
      <div class="stars stars-mid" data-parallax="0.12"></div>
      <div class="stars stars-near" data-parallax="0.22"></div>
    </div>

    <div class="wrap hero-inner">
      <span class="badge"><span class="dot"></span> Open source · runs entirely on-device</span>

      <div class="hero-mark">
        <div class="mark-glow" aria-hidden="true"></div>
        <Logo size={92} />
      </div>

      <h1>Your AI. Your phone.<br /><span class="h1-accent">Nobody else's business.</span></h1>

      <p class="hero-lede">
        Dhruva is named for ध्रुव — the pole star, the one fixed point in a turning sky that never
        needs a network or an audience to hold steady. The app is that idea in your pocket: every
        model runs on your phone, every answer is generated offline, and the only network call it
        ever makes is the one you start yourself.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href={repo} rel="noopener">
          Follow the build on GitHub
          <span class="btn-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.17-.89-1.17-.72-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.23 1.87.87 2.33.67.07-.52.28-.87.5-1.08-1.78-.2-3.65-.89-3.65-3.96 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.22 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.28.82 2.15 0 3.08-1.87 3.75-3.66 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"/></svg>
          </span>
        </a>
        <a class="btn btn-ghost" href={`${base}build/`}>
          Follow the build
          <span class="btn-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>

      <ul class="proof">
        {proof.map((p) => (
          <li><StarGlyph class="star-xs" /> {p}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================== WHAT WE'RE BUILDING ===================== -->
  <section class="section-tight what-head">
    <div class="wrap">
      <div class="section-head center reveal">
        <p class="eyebrow">What we're building</p>
        <h2>One app. Every model. Nothing leaves your device.</h2>
        <p>
          Dhruva is in active, open development. Here's the product taking shape, screen by screen —
          each preview below is drawn straight from the design system, not a marketing render.
        </p>
      </div>
    </div>
  </section>

  <Pillar
    index="01"
    eyebrow="Offline chat"
    title="A chat that never asks for a signal"
    body="Talk to any model you've downloaded, fully offline. Streaming responses with a live tokens-per-second readout, code blocks, and collapsible reasoning so you can watch the model think."
    points={[
      'Live <strong>tok/s</strong> ticker and markdown + code rendering',
      'Collapsible <strong>&lt;think&gt;</strong> reasoning, on by request not by default',
      'Regenerate, edit, export — history stays on device',
    ]}
  >
    <PhoneFrame label="Chat — streaming reply"><ChatMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="02"
    eyebrow="Model hub"
    title="Any GGUF from Hugging Face, no walled garden"
    body="Browse and pull quantized models straight from the Hub. Before you spend the bandwidth, Dhruva gives an honest device verdict based on the file size against your phone's RAM."
    points={[
      '<strong>Comfortable / Possible / Not recommended</strong> — no guessing',
      'Resumable, integrity-checked downloads',
      'Sideload your own fine-tunes too',
    ]}
    flip
  >
    <PhoneFrame label="Model hub — device verdicts"><ModelsHubMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="03"
    eyebrow="Characters"
    title="Personas with their own mind and memory"
    body="Give a model a name, a voice, and a standing system prompt. Build a Socratic tutor, a dungeon master that keeps the campaign log, or a focused assistant — each with its own memory."
    points={[
      'Custom system prompts per character',
      'Separate memory, separate conversations',
      'For roleplay or narrow, reliable helpers',
    ]}
  >
    <PhoneFrame label="Characters — persona gallery"><CharactersMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="04"
    eyebrow="Vision"
    title="Point it at anything and ask"
    body="Show Dhruva a photo, a screenshot, a boarding pass. A vision model reads it and answers your questions about what's in the frame — image understanding that never leaves the phone."
    points={[
      'On-device image understanding, no upload',
      'Screenshots, documents, photos',
      'The mmproj loads alongside the base model',
    ]}
    flip
  >
    <PhoneFrame label="Vision — ask about a photo"><VisionMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="05"
    eyebrow="Image generation"
    title="Make images without making a request"
    body="Quantized Stable Diffusion, generating on your phone's own compute. Type a prompt, watch it denoise step by step, and keep every pixel local — not one request leaves the device."
    points={[
      'Quantized diffusion, fully offline',
      'Live step-by-step progress',
      'Your prompts never touch a server',
    ]}
  >
    <PhoneFrame label="Imagine — on-device diffusion"><ImagineMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="06"
    eyebrow="Voice"
    title="A real conversation, not a walkie-talkie"
    body="Speech in, speech out, with genuine turn-taking — the model listens, knows when you've finished, and can be interrupted mid-answer. Speech recognition and synthesis both run on-device."
    points={[
      'VAD, turn-taking, and interruption',
      'STT and TTS on-device',
      'No push-to-talk bolt-on',
    ]}
    flip
  >
    <PhoneFrame label="Voice — live turn-taking"><VoiceMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="07"
    eyebrow="Chat with documents"
    title="Drop in a PDF, ask it anything"
    body="Dhruva indexes your document with on-device embeddings, retrieves the relevant passages, and answers with a citation back to the page — retrieval-augmented, with nothing uploaded."
    points={[
      'On-device embeddings and retrieval',
      'Answers cite the page they came from',
      'Your documents stay yours',
    ]}
  >
    <PhoneFrame label="Documents — cited answers"><DocsMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="08"
    eyebrow="AI toolbox"
    title="Small local tools, reached for mid-chat"
    body="Alarms, notes, quick calculations — the model can call small on-device tools right inside a conversation. The intent is handled on your phone; no assistant server is ever in the loop."
    points={[
      'Set alarms, save notes, run calculations',
      'Tool calls render inline and honestly',
      'Local intents, no cloud round-trip',
    ]}
    flip
  >
    <PhoneFrame label="Toolbox — inline tool call"><ToolboxMock /></PhoneFrame>
  </Pillar>

  <Pillar
    index="09"
    eyebrow="Playground + AI news"
    title="Compare models. Tune them. Stay current."
    body="Run one prompt across two models side by side, tune the sampling live, and read an opt-in digest of what's new in on-device AI — fetched only when you ask, never in the background."
    points={[
      'A / B compare with live sampling controls',
      'Opt-in AI news, fetched on request',
      'New in the roadmap (Loop 10.5)',
    ]}
  >
    <PhoneFrame label="Playground — A / B compare"><PlaygroundMock /></PhoneFrame>
  </Pillar>

  <!-- ===================== PRIVACY ===================== -->
  <section class="section privacy">
    <div class="wrap privacy-inner">
      <div class="privacy-lead reveal">
        <p class="eyebrow">Privacy, by construction</p>
        <h2>Not a policy.<br />An architecture.</h2>
        <p class="privacy-blurb">
          Most "private" AI apps mean "we promise not to look." Dhruva means the data physically
          never leaves. There is no server in the loop to make a promise about.
        </p>
        <div class="privacy-mark">
          <StarGlyph class="star-md" />
          <span>Runs 100% on your device</span>
        </div>
        <a class="prose-link" href={`${base}privacy/`}>
          Read the full privacy manifesto
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <ul class="privacy-points reveal">
        <li class="lift">
          <h3>Zero telemetry</h3>
          <p>No analytics SDKs, no crash reporters phoning home, no feature flags that call out. Nothing about how you use Dhruva leaves your device.</p>
        </li>
        <li class="lift">
          <h3>Downloads-only network</h3>
          <p>The single network call Dhruva ever makes is the one you ask for: fetching a model from Hugging Face. That's the entire network surface.</p>
        </li>
        <li class="lift">
          <h3>Open source, Apache-2.0</h3>
          <p>Every line is public. Don't take our word for the privacy claims — read the code, or point a network monitor at the app and watch.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ===================== BUILD IN PUBLIC ===================== -->
  <section class="section build-teaser">
    <div class="wrap build-inner reveal">
      <div class="build-copy">
        <p class="eyebrow">Built in public</p>
        <h2>Watch it get made, loop by loop</h2>
        <p>
          Dhruva is pre-alpha and shipped in the open. The engine is online, the model hub is live,
          and the chat experience is landing now. There's no installable build yet — it's coming via
          Firebase App Distribution — but the whole story so far is on the timeline.
        </p>
        <a class="btn btn-ghost" href={`${base}build/`}>
          See the build timeline
          <span class="btn-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
      <ul class="build-stats">
        <li><span class="stat-num">4</span><span class="stat-label">loops shipped</span></li>
        <li><span class="stat-num">100%</span><span class="stat-label">on-device inference</span></li>
        <li><span class="stat-num">0</span><span class="stat-label">telemetry calls</span></li>
      </ul>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="section final-cta">
    <div class="sky sky-cta" aria-hidden="true">
      <div class="stars stars-mid"></div>
    </div>
    <div class="wrap final-inner reveal">
      <div class="final-mark"><Logo size={56} /></div>
      <h2>The pole star doesn't rush to prove it's there.</h2>
      <p>Neither does Dhruva. Follow along, read the code, and help shape an AI that answers to no one but you.</p>
      <div class="hero-actions center">
        <a class="btn btn-primary" href={repo} rel="noopener">
          Star it on GitHub
          <span class="btn-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z"/></svg>
          </span>
        </a>
        <a class="btn btn-ghost" href={`${base}docs/`}>Read the docs</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(var(--space-6xl), 12vw, calc(var(--space-6xl) * 2));
    background:
      radial-gradient(120% 90% at 50% -10%, var(--color-surface) 0%, var(--color-background) 55%);
  }

  .sky {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .aurora {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 70%;
    background:
      radial-gradient(40% 60% at 22% 20%, color-mix(in srgb, var(--color-secondary) 20%, transparent), transparent 70%),
      radial-gradient(46% 60% at 78% 10%, color-mix(in srgb, var(--color-primary) 16%, transparent), transparent 70%);
    filter: blur(30px);
    opacity: 0.9;
  }

  .stars {
    position: absolute;
    inset: -20% 0 0 0;
    background-repeat: repeat;
    will-change: transform;
  }

  .stars-far {
    opacity: 0.5;
    background-image:
      radial-gradient(1px 1px at 12% 18%, var(--color-midnight-300) 99%, transparent),
      radial-gradient(1px 1px at 34% 42%, var(--color-midnight-300) 99%, transparent),
      radial-gradient(1px 1px at 58% 26%, var(--color-midnight-200) 99%, transparent),
      radial-gradient(1px 1px at 76% 52%, var(--color-midnight-300) 99%, transparent),
      radial-gradient(1px 1px at 88% 30%, var(--color-midnight-300) 99%, transparent),
      radial-gradient(1px 1px at 5% 62%, var(--color-midnight-300) 99%, transparent);
    background-size: 100% 100%;
  }

  .stars-mid {
    opacity: 0.7;
    background-image:
      radial-gradient(1.5px 1.5px at 20% 12%, var(--color-midnight-200) 99%, transparent),
      radial-gradient(1.5px 1.5px at 46% 30%, var(--color-star-gold-200) 99%, transparent),
      radial-gradient(1.5px 1.5px at 66% 16%, var(--color-midnight-100) 99%, transparent),
      radial-gradient(1.5px 1.5px at 84% 40%, var(--color-midnight-200) 99%, transparent),
      radial-gradient(1.5px 1.5px at 30% 54%, var(--color-midnight-200) 99%, transparent);
    background-size: 100% 100%;
  }

  .stars-near {
    opacity: 0.9;
    background-image:
      radial-gradient(2px 2px at 16% 24%, var(--color-star-gold-100) 99%, transparent),
      radial-gradient(2px 2px at 72% 22%, var(--color-midnight-50) 99%, transparent),
      radial-gradient(2px 2px at 90% 50%, var(--color-star-gold-200) 99%, transparent);
    background-size: 100% 100%;
  }

  @media (prefers-color-scheme: light) {
    .hero {
      background: radial-gradient(120% 90% at 50% -10%, var(--color-surface) 0%, var(--color-background) 60%);
    }
    .stars {
      opacity: 0.25;
    }
    .aurora {
      opacity: 0.5;
    }
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
  }

  .hero-mark {
    position: relative;
    display: grid;
    place-items: center;
    margin-top: var(--space-sm);
  }

  .mark-glow {
    position: absolute;
    width: 220px;
    height: 220px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 34%, transparent), transparent 62%);
    filter: blur(14px);
    z-index: -1;
  }

  .hero h1 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-large-weight);
    font-size: clamp(2.5rem, 6vw + 1rem, var(--text-display-large-size));
    line-height: var(--text-display-medium-line-height);
    letter-spacing: var(--text-display-large-tracking);
    color: var(--color-on-background);
    max-width: 18ch;
    text-wrap: balance;
  }

  .h1-accent {
    color: var(--color-primary);
  }

  .hero-lede {
    max-width: 60ch;
    color: var(--color-on-surface-variant);
    font-size: clamp(var(--text-body-large-size), 1vw + 0.8rem, var(--text-title-medium-size));
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-base);
    margin-top: var(--space-sm);
  }

  .hero-actions.center {
    justify-content: center;
  }

  .proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-base) var(--space-xl);
    margin-top: var(--space-lg);
  }

  .proof li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-label-large-size);
    font-weight: 600;
    color: var(--color-on-surface-variant);
  }

  /* ---------- What-we're-building header ---------- */
  .what-head {
    padding-top: clamp(var(--space-5xl), 8vw, calc(var(--space-6xl) + var(--space-3xl)));
  }

  /* ---------- Privacy ---------- */
  .privacy {
    border-top: 1px solid var(--color-outline-variant);
    background:
      radial-gradient(80% 60% at 15% 0%, color-mix(in srgb, var(--color-secondary) 8%, transparent), transparent 60%),
      var(--color-background);
  }

  .privacy-inner {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: clamp(var(--space-2xl), 5vw, var(--space-6xl));
    align-items: start;
  }

  .privacy-lead h2 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-small-weight);
    font-size: clamp(var(--text-headline-large-size), 3vw + 1rem, var(--text-display-medium-size));
    line-height: var(--text-headline-large-line-height);
    letter-spacing: var(--text-display-large-tracking);
    color: var(--color-on-background);
    margin-top: var(--space-base);
  }

  .privacy-blurb {
    margin-top: var(--space-lg);
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-large-size);
    max-width: 44ch;
  }

  .privacy-mark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding: var(--space-sm) var(--space-base);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    font-weight: 700;
    font-size: var(--text-label-large-size);
    color: var(--color-on-background);
  }

  .prose-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    color: var(--color-secondary);
    text-decoration: none;
    font-weight: 700;
  }

  .prose-link:hover {
    gap: var(--space-md);
  }

  .privacy-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-base);
  }

  .privacy-points li {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
  }

  .privacy-points h3 {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-title-large-size);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .privacy-points p {
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-medium-size);
    max-width: 54ch;
  }

  /* ---------- Build teaser ---------- */
  .build-teaser {
    border-top: 1px solid var(--color-outline-variant);
    background: var(--color-surface);
  }

  .build-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(var(--space-2xl), 5vw, var(--space-5xl));
    align-items: center;
  }

  .build-copy h2 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-small-weight);
    font-size: clamp(var(--text-headline-medium-size), 2.4vw + 1rem, var(--text-display-small-size));
    line-height: var(--text-headline-large-line-height);
    color: var(--color-on-background);
    margin-top: var(--space-base);
  }

  .build-copy p {
    margin-block: var(--space-base) var(--space-xl);
    color: var(--color-on-surface-variant);
    max-width: 56ch;
  }

  .build-stats {
    display: grid;
    gap: var(--space-base);
  }

  .build-stats li {
    display: flex;
    align-items: baseline;
    gap: var(--space-base);
    padding: var(--space-base) var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--color-background);
    border: 1px solid var(--color-outline-variant);
  }

  .stat-num {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-headline-medium-size);
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
    min-width: 3ch;
  }

  .stat-label {
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-medium-size);
  }

  /* ---------- Final CTA ---------- */
  .final-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-top: 1px solid var(--color-outline-variant);
    background: radial-gradient(100% 100% at 50% 120%, var(--color-surface) 0%, var(--color-background) 60%);
    text-align: center;
  }

  .sky-cta {
    opacity: 0.6;
  }

  .final-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .final-mark {
    display: grid;
    place-items: center;
  }

  .final-cta h2 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-small-weight);
    font-size: clamp(var(--text-headline-medium-size), 3vw + 1rem, var(--text-display-medium-size));
    line-height: var(--text-headline-large-line-height);
    letter-spacing: var(--text-display-large-tracking);
    color: var(--color-on-background);
    max-width: 20ch;
    text-wrap: balance;
  }

  .final-cta p {
    color: var(--color-on-surface-variant);
    max-width: 52ch;
    font-size: var(--text-body-large-size);
  }

  @media (max-width: 52rem) {
    .privacy-inner,
    .build-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
