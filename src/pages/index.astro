---
// ponytail: honest pre-alpha placeholder — the real site (tokens-themed) is Loop 12
const repo = 'https://github.com/AnshRajput/dhruva-app';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Dhruva AI — open-source AI that runs 100% on your phone. Offline chat, characters, vision, image generation, voice, and document chat. Zero telemetry."
		/>
		<title>Dhruva AI — Your AI. Your phone. Nobody else's business.</title>
		<style>
			:root {
				color-scheme: dark;
			}
			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				background: #0e1220;
				color: #f2f3f7;
				font-family: system-ui, sans-serif;
				text-align: center;
				padding: 2rem;
			}
			h1 {
				font-size: clamp(2.5rem, 8vw, 4.5rem);
				margin: 0 0 0.5rem;
				color: #ebba47;
				letter-spacing: -0.02em;
			}
			p {
				max-width: 34rem;
				line-height: 1.6;
				opacity: 0.85;
			}
			a {
				color: #ebba47;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Dhruva AI</h1>
			<p><strong>Your AI. Your phone. Nobody else's business.</strong></p>
			<p>
				An open-source app that runs AI models entirely on your device — offline
				chat, characters, vision, image generation, voice, and document chat.
				Zero telemetry. Currently in early development, built in public.
			</p>
			<p><a href={repo}>Follow the build on GitHub →</a></p>
		</main>
	</body>
</html>
