---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';

const repo = 'https://github.com/AnshRajput/dhruva-app';
const base = import.meta.env.BASE_URL;

const features = [
  {
    title: 'Offline chat',
    body: 'Talk to any model you download — no connection required once it’s on your device.',
  },
  {
    title: 'Any GGUF from Hugging Face',
    body: 'Browse and pull quantized models straight from the Hub. No walled garden, no approval queue.',
  },
  {
    title: 'Characters',
    body: 'Custom personas with their own system prompts and memory, for roleplay or focused assistants.',
  },
  {
    title: 'Vision',
    body: 'Point it at a photo or screenshot and ask questions — image understanding, entirely on-phone.',
  },
  {
    title: 'Image generation',
    body: 'Quantized Stable Diffusion, generating images without a single request leaving your device.',
  },
  {
    title: 'Voice',
    body: 'Speech in, speech out, with real turn-taking — not a walkie-talkie push-to-talk bolt-on.',
  },
  {
    title: 'Document chat',
    body: 'Drop in a PDF and ask it questions, retrieved and answered with on-device embeddings.',
  },
  {
    title: 'One-tap toolbox',
    body: 'Alarms, notes, quick calculations — small local tools the model can reach for mid-conversation.',
  },
];

const privacyPoints = [
  {
    title: 'Zero telemetry',
    body: 'No analytics SDKs, no crash reporters phoning home, no feature flags that call out. Nothing about how you use Dhruva leaves your device.',
  },
  {
    title: 'Downloads-only network',
    body: 'The only network calls Dhruva ever makes are the ones you ask for: fetching a model from Hugging Face. That’s the entire network surface.',
  },
  {
    title: 'Open source, Apache-2.0',
    body: 'Every line is public. Don’t take our word for the privacy claims — read the code, or watch it in a network monitor.',
  },
];
---

<Base
  title="Dhruva AI — Your AI. Your phone. Nobody else's business."
  description="Dhruva AI is an open-source app that runs AI models 100% on your device — offline chat, characters, vision, image generation, voice, and document chat. Zero telemetry, Apache-2.0."
>
  <section class="hero">
    <div class="starfield" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <Logo size={96} class="hero-mark" />
      <p class="eyebrow">Open source &middot; runs entirely on-device</p>
      <h1>Your AI. Your phone.<br />Nobody else's business.</h1>
      <p class="hero-lede">
        Dhruva is named for &#2343;&#2381;&#2352;&#2369;&#2357; &mdash; the pole star, the one fixed point in a
        turning sky that never needs a network or an audience to hold steady. The app is the same
        idea: every model runs on your phone, every inference happens offline, and the only
        network call Dhruva ever makes is the one you start yourself &mdash; downloading a model.
      </p>
      <p class="hero-sub">No account. No cloud. No one watching.</p>

      <div class="hero-actions">
        <a class="btn-primary" href={repo} rel="noopener">
          Follow the build on GitHub
        </a>
        <a class="btn-secondary" href={`${base}models/`}>See supported models</a>
      </div>

      <div class="screenshot-frame">
        <div class="screenshot-placeholder">
          <Logo size={40} />
          <p>In development &mdash; follow the build</p>
          <span>Real app screenshots land as loops ship.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">What it does</p>
      <h2>One app, entirely local</h2>
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature-card">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section privacy-section">
    <div class="wrap">
      <p class="eyebrow">Privacy, by construction</p>
      <h2>Not a policy. An architecture.</h2>
      <div class="privacy-grid">
        {
          privacyPoints.map((p) => (
            <article class="privacy-card">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </article>
          ))
        }
      </div>
      <a class="prose-link" href={`${base}privacy/`}>Read the full privacy manifesto &rarr;</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-6xl) var(--space-4xl);
    background: var(--color-background);
  }

  .starfield {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.5;
    background-image:
      radial-gradient(1.5px 1.5px at 8% 18%, var(--color-midnight-400) 100%, transparent 0),
      radial-gradient(1px 1px at 22% 8%, var(--color-midnight-300) 100%, transparent 0),
      radial-gradient(1.5px 1.5px at 38% 24%, var(--color-midnight-400) 100%, transparent 0),
      radial-gradient(1px 1px at 55% 6%, var(--color-midnight-300) 100%, transparent 0),
      radial-gradient(1.5px 1.5px at 68% 20%, var(--color-midnight-400) 100%, transparent 0),
      radial-gradient(1px 1px at 82% 10%, var(--color-midnight-300) 100%, transparent 0),
      radial-gradient(1.5px 1.5px at 92% 26%, var(--color-midnight-400) 100%, transparent 0),
      radial-gradient(1px 1px at 12% 40%, var(--color-midnight-300) 100%, transparent 0),
      radial-gradient(1px 1px at 47% 38%, var(--color-midnight-300) 100%, transparent 0),
      radial-gradient(1px 1px at 78% 42%, var(--color-midnight-300) 100%, transparent 0);
    background-repeat: no-repeat;
    mask-image: linear-gradient(to bottom, black, transparent 85%);
  }

  @media (prefers-color-scheme: light) {
    .starfield {
      opacity: 0.18;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-base);
  }

  .hero-inner :global(.hero-mark) {
    margin-bottom: var(--space-sm);
  }

  .hero-inner h1 {
    font-family: var(--font-family-display);
    font-weight: var(--text-display-medium-weight);
    font-size: clamp(2.25rem, 5vw + 1rem, var(--text-display-large-size));
    line-height: var(--text-display-medium-line-height);
    letter-spacing: var(--text-display-large-tracking);
    color: var(--color-on-background);
    max-width: 20ch;
  }

  .hero-lede {
    max-width: 56ch;
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-large-size);
  }

  .hero-sub {
    font-weight: 600;
    color: var(--color-on-background);
    opacity: 0.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-base);
    margin-top: var(--space-sm);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-weight: 700;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-full);
    transition: transform var(--duration-fast) var(--easing-standard);
  }

  .btn-primary:hover {
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-on-background);
    font-weight: 600;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-outline);
  }

  .btn-secondary:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  .screenshot-frame {
    margin-top: var(--space-4xl);
    width: min(20rem, 80vw);
    aspect-ratio: 9 / 18;
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-xl);
    padding: var(--space-sm);
    background: var(--color-surface);
  }

  .screenshot-placeholder {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    text-align: center;
    padding: var(--space-lg);
    border-radius: calc(var(--radius-xl) - var(--space-sm));
    border: 1px dashed var(--color-outline-variant);
    background: var(--color-surface-variant);
  }

  .screenshot-placeholder p {
    font-weight: 700;
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-medium-size);
  }

  .screenshot-placeholder span {
    font-size: var(--text-body-small-size);
    color: var(--color-on-surface-variant);
  }

  .section {
    padding-block: var(--space-6xl);
  }

  .section h2 {
    font-family: var(--font-family-display);
    font-weight: var(--text-headline-large-weight);
    font-size: var(--text-headline-large-size);
    line-height: var(--text-headline-large-line-height);
    color: var(--color-on-background);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-3xl);
    max-width: 24ch;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-outline-variant);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .feature-card {
    background: var(--color-surface);
    padding: var(--space-xl);
  }

  .feature-card h3 {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-title-large-size);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .feature-card p {
    font-size: var(--text-body-medium-size);
    color: var(--color-on-surface-variant);
  }

  .privacy-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-outline-variant);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .privacy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .privacy-card h3 {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-title-large-size);
    color: var(--color-on-background);
    margin-bottom: var(--space-sm);
  }

  .privacy-card p {
    font-size: var(--text-body-medium-size);
    color: var(--color-on-surface-variant);
  }

  .prose-link {
    color: var(--color-secondary);
    text-decoration: none;
    font-weight: 700;
  }

  .prose-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 64rem) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .privacy-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 32rem) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
