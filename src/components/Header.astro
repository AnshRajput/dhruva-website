---
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL; // ends with '/'
const path = Astro.url.pathname;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}models/`, label: 'Models' },
  { href: `${base}build/`, label: 'Build' },
  { href: `${base}privacy/`, label: 'Privacy' },
  { href: `${base}docs/`, label: 'Docs' },
];

function isActive(href: string) {
  if (href === base) return path === base || path === base.slice(0, -1);
  return path.startsWith(href);
}
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={base} aria-label="Dhruva AI home">
      <Logo size={28} />
      <span class="wordmark">Dhruva</span>
    </a>

    <nav id="primary-nav" class="nav" aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="gh-cta" href="https://github.com/AnshRajput/dhruva-app" rel="noopener">
      <span>GitHub</span>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path
          d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.17-.89-1.17-.72-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.23 1.87.87 2.33.67.07-.52.28-.87.5-1.08-1.78-.2-3.65-.89-3.65-3.96 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.22 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.28.82 2.15 0 3.08-1.87 3.75-3.66 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"
        />
      </svg>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Menu"
      aria-controls="primary-nav"
      aria-expanded="false"
    >
      <span class="nav-toggle-bars" aria-hidden="true"><i></i><i></i></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-background) 82%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-base);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    margin-right: auto;
    flex-shrink: 0;
  }

  .wordmark {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: var(--text-title-large-size);
    color: var(--color-on-background);
  }

  .nav ul {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: nowrap;
  }

  .nav a {
    display: block;
    text-decoration: none;
    font-size: var(--text-body-medium-size);
    font-weight: 600;
    color: var(--color-on-surface-variant);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--easing-standard);
  }

  .nav a:hover,
  .nav a[aria-current='page'] {
    color: var(--color-on-background);
  }

  .gh-cta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    font-size: var(--text-label-large-size);
    font-weight: 700;
    color: var(--color-on-background);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-full);
    padding: var(--space-sm) var(--space-base);
    flex-shrink: 0;
    transition:
      border-color var(--duration-fast) var(--easing-standard),
      background var(--duration-fast) var(--easing-standard);
  }

  .gh-cta svg {
    flex-shrink: 0;
  }

  .gh-cta:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-container);
  }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-full);
    background: transparent;
    cursor: pointer;
    place-items: center;
  }

  .nav-toggle-bars {
    position: relative;
    width: 16px;
    height: 12px;
    display: block;
  }

  .nav-toggle-bars i {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: var(--radius-full);
    background: var(--color-on-background);
    transition: transform var(--duration-base) var(--easing-emphasized), opacity var(--duration-fast) var(--easing-standard);
  }

  .nav-toggle-bars i:nth-child(1) { top: 2px; }
  .nav-toggle-bars i:nth-child(2) { bottom: 2px; }

  .nav-toggle[aria-expanded='true'] .nav-toggle-bars i:nth-child(1) {
    transform: translateY(3px) rotate(45deg);
  }

  .nav-toggle[aria-expanded='true'] .nav-toggle-bars i:nth-child(2) {
    transform: translateY(-3px) rotate(-45deg);
  }

  @media (max-width: 46rem) {
    .nav-toggle {
      display: grid;
    }

    .gh-cta span {
      display: none;
    }

    /* Nav becomes a dropdown panel */
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: color-mix(in srgb, var(--color-background) 96%, transparent);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--color-outline-variant);
      padding: var(--space-sm) var(--space-xl) var(--space-lg);
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      visibility: hidden;
      transition:
        grid-template-rows var(--duration-moderate) var(--easing-decelerate),
        opacity var(--duration-base) var(--easing-standard),
        visibility var(--duration-base) var(--easing-standard);
    }

    .nav[data-open='true'] {
      opacity: 1;
      visibility: visible;
      grid-template-rows: 1fr;
    }

    .nav ul {
      flex-direction: column;
      gap: 0;
      overflow: hidden;
      min-height: 0;
    }

    .nav li {
      border-bottom: 1px solid var(--color-outline-variant);
    }

    .nav li:last-child {
      border-bottom: none;
    }

    .nav a {
      padding-block: var(--space-md);
      font-size: var(--text-title-medium-size);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.getElementById('primary-nav');

  if (toggle && nav) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      nav.dataset.open = String(open);
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Close on link tap, Escape, or outside click.
    nav.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (
        toggle.getAttribute('aria-expanded') === 'true' &&
        !(e.target as HTMLElement).closest('.site-header')
      ) {
        setOpen(false);
      }
    });
  }
</script>
