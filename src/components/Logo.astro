---
// Live pole-star mark — see src/lib/logo-mark.mjs for the geometry and its
// derivation from orchestra/research/brand-proposal.md (b) in dhruva-app.
// Colors come from tokens.css custom properties, so this flips with theme
// automatically; no hardcoded hex here.
import { STAR_VIEWBOX, STAR_CENTER, STAR_PINHOLE_RADIUS, STAR_PATH_D } from '../lib/logo-mark.mjs';

interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox={STAR_VIEWBOX}
  role="img"
  aria-label="Dhruva pole-star mark"
>
  <path d={STAR_PATH_D} fill="var(--color-primary)" />
  <circle cx={STAR_CENTER.x} cy={STAR_CENTER.y} r={STAR_PINHOLE_RADIUS} fill="var(--color-background)" />
</svg>
