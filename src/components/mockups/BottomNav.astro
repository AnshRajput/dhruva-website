---
// Bottom tab bar for app-shell mocks that don't have a composer, so the phone
// screen reads like a real app instead of leaving empty space. Token-driven.
interface Props {
  active?: 'chat' | 'hub' | 'voice' | 'you';
}
const { active = 'hub' } = Astro.props;
const items = [
  { id: 'chat', label: 'Chat', d: 'M4 4h16v12H8l-4 4V4z' },
  { id: 'hub', label: 'Hub', d: 'M4 4h7v7H4V4zm9 0h7v7h-7V4zM4 13h7v7H4v-7zm9 0h7v7h-7v-7z' },
  { id: 'voice', label: 'Voice', d: 'M12 3a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V6a3 3 0 0 1 3-3zM5 11a7 7 0 0 0 14 0M12 18v3' },
  { id: 'you', label: 'You', d: 'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM4 21a8 8 0 0 1 16 0' },
];
---

<nav class="mk-tabbar" aria-hidden="true">
  {
    items.map((it) => (
      <span class:list={['mk-tabitem', { on: it.id === active }]}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={it.d} /></svg>
        <span>{it.label}</span>
      </span>
    ))
  }
</nav>
