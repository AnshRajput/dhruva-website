---
// Any-GGUF Hugging Face browser with device verdicts. Real repo IDs, real
// verdict logic (file-size bucket vs device RAM), a live resumable download.
import BottomNav from './BottomNav.astro';
---

<div class="mk-appbar">
  <span class="mk-title">Model hub</span>
  <span class="mk-spacer"></span>
  <span class="mk-chip">RAM 6 GB</span>
</div>

<div class="mk-body">
  <div class="mk-composer" style="border:1px solid var(--color-outline-variant); border-top:1px solid var(--color-outline-variant); border-radius:var(--radius-full); background:var(--color-surface-variant); padding:5px 9px;">
    <svg class="mk-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
    <span class="mk-field" style="background:transparent; padding:0;">Search GGUF on Hugging Face…</span>
  </div>

  <div class="mk-list">
    <div class="mk-rowcard">
      <div class="mk-row-top">
        <span class="mk-name">Llama-3.2-1B-Instruct</span>
        <span class="mk-verdict good">Comfortable</span>
      </div>
      <div class="mk-mono">bartowski/Llama-3.2-1B-Instruct-GGUF</div>
      <div class="mk-sub">Q4_K_M · ~770 MB · chat</div>
    </div>

    <div class="mk-rowcard">
      <div class="mk-row-top">
        <span class="mk-name">Phi-4-mini-instruct</span>
        <span class="mk-verdict ok">Possible</span>
      </div>
      <div class="mk-mono">unsloth/Phi-4-mini-instruct-GGUF</div>
      <div class="mk-sub">Downloading · 62% · resumable</div>
      <div class="mk-progress"><span style="width:62%"></span></div>
    </div>

    <div class="mk-rowcard">
      <div class="mk-row-top">
        <span class="mk-name">SmolVLM2-2.2B</span>
        <span class="mk-verdict no">Not recommended</span>
      </div>
      <div class="mk-mono">ggml-org/SmolVLM2-2.2B-Instruct-GGUF</div>
      <div class="mk-sub">Q4_K_M + mmproj · ~1.6 GB · vision</div>
    </div>
  </div>
</div>

<BottomNav active="hub" />
